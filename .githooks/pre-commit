#!/usr/bin/env sh
set -eu

IMAGE="${PRE_COMMIT_IMAGE:-repo-starter-kit-pre-commit}"
ROOT="$(git rev-parse --show-toplevel)"

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "[pre-commit] Docker イメージが未ビルドです。まず 'make init' を実行してください。" 1>&2
  exit 1
fi

exec docker run --rm -v "$ROOT:/workspace" -w /workspace "$IMAGE" \
  pre-commit run --hook-stage commit --all-files
